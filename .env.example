# ===========================================
# INORDIO ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# -------------------------------------------
# DATABASE
# -------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/inordio_dev"

# -------------------------------------------
# APPLICATION
# -------------------------------------------
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -------------------------------------------
# AUTHENTICATION
# -------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# -------------------------------------------
# ENCRYPTION
# -------------------------------------------
# Generate with: openssl rand -base64 32
# WARNING: Changing this will make existing encrypted data unreadable
ENCRYPTION_MASTER_SALT="your-salt-here"

# -------------------------------------------
# PAYMENT PROVIDERS (Canadian)
# -------------------------------------------
# Stripe - https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Square - https://developer.squareup.com
SQUARE_ACCESS_TOKEN=""
SQUARE_APPLICATION_ID=""
SQUARE_LOCATION_ID=""

# Rotessa (PAD) - https://rotessa.com
ROTESSA_API_KEY=""
ROTESSA_CLIENT_ID=""

# PayPal - https://developer.paypal.com
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# -------------------------------------------
# DISCORD BOT
# -------------------------------------------
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# -------------------------------------------
# OCR / RECEIPT SCANNING
# -------------------------------------------
# Google Cloud Vision - https://console.cloud.google.com
GOOGLE_CLOUD_VISION_API_KEY=""

# OR AWS Textract
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ca-central-1"

# -------------------------------------------
# SAGE ACCOUNTING
# -------------------------------------------
SAGE_CLIENT_ID=""
SAGE_CLIENT_SECRET=""
SAGE_REDIRECT_URI="http://localhost:3000/api/integrations/sage/callback"

# -------------------------------------------
# FILE STORAGE (S3-Compatible)
# -------------------------------------------
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="inordio-files"
S3_REGION="ca-central-1"

# -------------------------------------------
# EMAIL
# -------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@inordio.ca"

# -------------------------------------------
# DEVELOPMENT
# -------------------------------------------
# Set to true to seed demo data
SEED_DATABASE="false"
