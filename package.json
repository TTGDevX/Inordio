{
  "name": "inordio",
  "version": "0.1.0",
  "private": true,
  "description": "Field service management platform - inventory, jobs, invoicing for trades businesses",
  "author": "TTG Development <dev@ttgonline.ca>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "db:generate": "pnpm --filter @inordio/database generate",
    "db:migrate": "pnpm --filter @inordio/database migrate:dev",
    "db:push": "pnpm --filter @inordio/database push",
    "db:studio": "pnpm --filter @inordio/database studio",
    "db:seed": "pnpm --filter @inordio/database seed",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
